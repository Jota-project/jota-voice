# Plantilla de variables de entorno locales del repo.
# Copia este fichero a .env.local (gitignored) y rellena los valores.
#
# Política: este fichero NO contiene valores reales. Solo placeholders
# genéricos. El .env.local con tus valores vive en tu máquina y está
# excluido del repo por .gitignore.

# SSH al servidor del gateway (usuario@ip-o-hostname)
GATEWAY_SSH_HOST=usuario@192.168.X.X

# URL del gateway WebSocket. La usa:
#   - install/macos/02-config-wizard.sh si GATEWAY_URL está exportada,
#     no pregunta al usuario al crear devices/<id>/config.yaml.
#   - el cliente jota-voice como override de la URL definida en config.yaml.
#
# Política: escribe la URL EXACTA del gateway. El cliente la respeta
# literal — NO añade scheme, puerto ni path por defecto. Si tu gateway
# vive detrás de un proxy inverso / Tunnel, una URL del tipo
#   wss://host/ruta
# (sin puerto explícito) funciona tal cual.
GATEWAY_URL=wss://CHANGE-ME.example.com/api/gateway/ws/stream

# Client key del gateway (jota-db). Igual que GATEWAY_URL: si está
# exportada, el wizard no pregunta.
GATEWAY_CLIENT_KEY=CHANGE-ME

# Las credenciales de deploy a dispositivos Termux/Android viven en
# devices/<nombre>.env (ver devices/example.env), no aquí.